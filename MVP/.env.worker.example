# Copy to MVP/.env.worker and fill in your Supabase project values.
# This file is NOT committed to the repo.
#
# Find these in: Supabase Dashboard → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co

# The service role key has full DB + Storage access — keep it private.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 bucket that stores original uploaded videos.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_VIDEOS_BUCKET=ski-videos
# Optional: separate bucket for large generated artifacts like overlay.mp4
# R2_ARTIFACTS_BUCKET=ski-artifacts

# Gemini API key for AI coaching feedback (optional — skipped if not set)
# GEMINI_API_KEY=your-gemini-api-key

# Optional: poll interval in seconds (default 10)
# WORKER_POLL_INTERVAL=10

# Optional: seconds before a running job is considered stale (default 600)
# WORKER_STALE_THRESHOLD=600
