# Copy to MVP/.env.worker and fill in your Supabase project values.
# This file is NOT committed to the repo.
#
# Find these in: Supabase Dashboard → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co

# The service role key has full DB + Storage access — keep it private.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 bucket that stores original uploaded videos.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_VIDEOS_BUCKET=ski-videos
# Optional: separate bucket for large generated artifacts like overlay.mp4
# R2_ARTIFACTS_BUCKET=ski-artifacts

# LM Studio local server for AI coaching feedback
# Default server URL is http://localhost:1234 if omitted
# LMSTUDIO_BASE_URL=http://localhost:1234
# Optional: if LM Studio auth is enabled
# LMSTUDIO_API_KEY=lm-studio
# Optional: pin a specific loaded model id. If omitted, the worker uses the
# first model returned by LM Studio's /v1/models endpoint.
# LMSTUDIO_MODEL=your-loaded-model-id

# Optional: poll interval in seconds (default 10)
# WORKER_POLL_INTERVAL=10

# Optional: seconds before a running job is considered stale (default 600)
# WORKER_STALE_THRESHOLD=600
