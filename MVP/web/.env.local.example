# Copy to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Never expose this key to the browser — only used in server-side API routes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 credentials for original video uploads.
# Create an R2 bucket for uploads, then create an API token/access key pair with read/write access.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_VIDEOS_BUCKET=ski-videos
# Optional: separate bucket for large generated artifacts like overlay.mp4
# R2_ARTIFACTS_BUCKET=ski-artifacts
